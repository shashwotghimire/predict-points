NODE_ENV=development
API_PORT=3001

# Required in production
DATABASE_URL=postgresql://user:password@localhost:5432/predict_points
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Use strong random secrets (32+ chars) in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_TTL_DAYS=30
ACCESS_TOKEN_TTL_MS=900000
REFRESH_TOKEN_TTL_MS=2592000000

# Cookie/security
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_PARTITIONED=false
COOKIE_DOMAIN=
TRUST_PROXY=false
REQUEST_BODY_LIMIT=512kb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
REFRESH_RATE_LIMIT_MAX=60

# Optional: local sample data (disabled by default; never enable in production)
ENABLE_SAMPLE_DATA=false

# Optional: one-time admin bootstrap (use only for controlled setup)
BOOTSTRAP_ADMIN=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=System Admin

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# Optional: Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
