generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  SUPER_ADMIN
  MODERATOR
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
  CANCELLED
}

enum MarketType {
  YES_NO
  MULTI_4
  OVER_UNDER
}

enum MarketCategory {
  TRENDING
  POLITICS
  SPORTS
}

enum TransactionType {
  BET
  WIN
  REFUND
  BONUS
  PENALTY
}

enum PredictionStatus {
  ACTIVE
  WON
  LOST
  VOID
}

enum ActivityType {
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  EVENT_DECLARED
  PREDICTION_SUBMITTED
  COMMENT_ADDED
  REWARD_REDEEMED
}

enum RewardStatus {
  REDEEMED
  CANCELLED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  phoneNumber       String?
  password          String
  authProvider      AuthProvider       @default(LOCAL)
  googleId          String?            @unique
  refreshTokenHash  String?
  refreshTokenExp   DateTime?
  profilePicUrl     String?
  role              UserRole           @default(USER)
  points            Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  createdMarkets    Market[]           @relation("CreatedMarkets")
  predictions       Prediction[]
  pointTransactions PointTransaction[]
  comments          EventComment[]
  activities        ActivityLog[]
  rewardRedemptions RewardRedemption[]
}

model Reward {
  id             String             @id @default(cuid())
  name           String
  description    String?
  pointsRequired Int
  iconKey        String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  redemptions RewardRedemption[]

  @@index([isActive, createdAt])
}

model Market {
  id               String           @id @default(cuid())
  title            String
  description      String?
  category         MarketCategory   @default(TRENDING)
  type             MarketType       @default(YES_NO)
  status           MarketStatus     @default(OPEN)
  eventIconUrl     String?
  closesAt         DateTime
  isDeclared       Boolean          @default(false)
  declaredAt       DateTime?
  declaredOptionId String?
  createdById      String?

  createdBy      User?             @relation("CreatedMarkets", fields: [createdById], references: [id])
  declaredOption Option?           @relation("DeclaredOption", fields: [declaredOptionId], references: [id])
  options        Option[]          @relation("MarketOptions")
  predictions    Prediction[]
  resolution     MarketResolution?
  oddsSnapshots  OddsSnapshot[]
  comments       EventComment[]
  activities     ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, status])
  @@index([type])
  @@index([createdById])
}

model Option {
  id         String @id @default(cuid())
  label      String
  percentage Int    @default(50)
  marketId   String

  market            Market              @relation("MarketOptions", fields: [marketId], references: [id])
  predictions       Prediction[]
  marketResolutions MarketResolution[]
  oddsSnapshots     OddsSnapshot[]
  declaredInMarkets Market[]            @relation("DeclaredOption")

  createdAt DateTime @default(now())

  @@index([marketId])
}

model Prediction {
  id                String           @id @default(uuid())
  userId            String
  marketId          String
  optionId          String
  pointsStaked      Int
  potentialWinnings Int              @default(0)
  status            PredictionStatus @default(ACTIVE)
  isWinning         Boolean          @default(false)
  resolvedAt        DateTime?

  user   User   @relation(fields: [userId], references: [id])
  market Market @relation(fields: [marketId], references: [id])
  option Option @relation(fields: [optionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, marketId])
  @@index([marketId, status])
  @@index([userId, status])
}

model MarketResolution {
  id       String @id @default(uuid())
  marketId String @unique
  optionId String

  market Market @relation(fields: [marketId], references: [id])
  option Option @relation(fields: [optionId], references: [id])

  resolvedAt DateTime @default(now())
}

model OddsSnapshot {
  id         String   @id @default(uuid())
  marketId   String
  optionId   String
  percentage Int
  createdAt  DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id])
  option Option @relation(fields: [optionId], references: [id])

  @@index([marketId, createdAt])
  @@index([optionId, createdAt])
}

model EventComment {
  id        String   @id @default(uuid())
  marketId  String
  userId    String
  content   String
  createdAt DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
}

model ActivityLog {
  id        String       @id @default(uuid())
  userId    String?
  marketId  String?
  type      ActivityType
  message   String
  createdAt DateTime     @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  market Market? @relation(fields: [marketId], references: [id])

  @@index([createdAt])
  @@index([marketId, createdAt])
}

model RewardRedemption {
  id          String       @id @default(uuid())
  userId      String
  rewardId    String?
  rewardName  String
  pointsSpent Int
  status      RewardStatus @default(REDEEMED)
  createdAt   DateTime     @default(now())

  user   User    @relation(fields: [userId], references: [id])
  reward Reward? @relation(fields: [rewardId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([rewardId])
}

model PointTransaction {
  id     String          @id @default(uuid())
  userId String
  amount Int
  type   TransactionType
  reason String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
